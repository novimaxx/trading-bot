# ─── Telegram ────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# ─── Порт сервера ─────────────────────────────────────────
PORT=3000

# ─── Таймфреймы (false = выключить) ──────────────────────
TF_1D=true
TF_4H=true
TF_1H=true
TF_15M=false

# ─── Сигналы (false = выключить) ─────────────────────────
SIGNAL_BUY25=false        # BUY 25% — часто шумит, лучше выкл
SIGNAL_BUY50=true
SIGNAL_BUY100=true
SIGNAL_SELL50=true
SIGNAL_SELL100=true
SIGNAL_STRONG=true        # STRONG BUY/SELL (объём + RSI + тренд)
SIGNAL_TREND=true         # Пересечение оранжевой SMA
SIGNAL_HOLD=false         # Удержание уровня 5 баров
SIGNAL_STRUCTURE=true     # Слом структуры (LH/HL)
SIGNAL_LIQ=true           # Ликвидность (найдена / пробита)
SIGNAL_PIVOT=true         # Пивот HH/LL + Фибоначчи (только 1D)
